import seaborn as sns
from sklearn.datasets import make_blobs # we create data for cluster


X, y = make_blobs(
    n_samples=1000,
    n_features=2,
    centers=4, # No. of clusters
    random_state=42
)
# X contains the feature coordinates of each data point, while y contains the cluster label indicating which cluster each point belongs to.


#visualize
sns.scatterplot(x=X[:, 0], y=X[:, 1])


# K-Means Clustering
import os
os.environ["OMP_NUM_THREADS"] = "4"
from sklearn.cluster import KMeans 


K = 4

kmeans = KMeans(
    n_clusters=K,
    random_state=42
)


labels = kmeans.fit_predict(X)
#labels = cluster number


sns.scatterplot(x=X[:, 0], y=X[:, 1], c=labels)





# Elbow method
wcss = []
for k in range(1, 21):
    kmeans = KMeans(n_clusters=k)
    kmeans.fit_predict(X)
    wcss.append(kmeans.inertia_)
    


sns.lineplot(x=range(1, 21), y=wcss, marker='o')


# kneed Module

!pip install kneed
# kneed is a Python library used to automatically find the “knee” or “elbow point” in a curve.


from kneed import KneeLocator


knee = KneeLocator(range(1, 21), wcss, curve="convex", direction="decreasing")


print("Optimal KValue: ",knee.elbow)



